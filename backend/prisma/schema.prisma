generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id       Int    @id @default(autoincrement())
  username String @unique
  password String
  role     String // admin or staff
}

model Medicine {
  id             Int      @id @default(autoincrement())
  name           String
  category       String
  batchNumber    String
  expiryDate     DateTime
  purchasePrice  Float
  sellingPrice   Float
  quantity       Int

  purchases Purchase[]
  sales Sale[]
}

model Supplier {
  id      Int    @id @default(autoincrement())
  name    String
  contact String
  address String

  purchases Purchase[]
}

model Purchase {
  id          Int      @id @default(autoincrement())
  medicineId  Int
  supplierId  Int
  quantity    Int
  totalPrice  Float
  purchaseDate DateTime @default(now())

  medicine Medicine @relation(fields: [medicineId], references: [id])
  supplier Supplier @relation(fields: [supplierId], references: [id])
}

model Sale {
  id         Int      @id @default(autoincrement())
  medicineId Int
  quantity   Int
  totalPrice Float
  saleDate   DateTime @default(now())

  medicine Medicine @relation(fields: [medicineId], references: [id])
}